{
  "name": "app-launcher",
  "version": "1.0.0",
  "private": true,
  "description": "A local-first Windows desktop launcher for applications, folders and protocol links.",
  "author": "Ali Mozaffari",
  "type": "module",
  "main": "electron-main.cjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:vite --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['dist','dist-desktop']) fs.rmSync(p,{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test",
    "check": "npm run lint && npm run build && node --test",
    "desktop:start": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "@google/genai": "^2.10.0",
    "dotenv": "^17.4.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.12",
    "express": "^4.22.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "~5.8.3",
    "vite": "^6.4.3"
  },
  "build": {
    "appId": "com.applauncher.desktop",
    "productName": "App Launcher",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "artifactName": "App-Launcher-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "electron-main.cjs",
      "electron-preload.cjs",
      "package.json"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
